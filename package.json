{
  "name": "comikaiju",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "postinstall": "npm run setup:libarchive",
    "setup:libarchive": "mkdir -p static/libarchive && cp -r node_modules/libarchive.js/dist/* static/libarchive/ 2>/dev/null || echo 'libarchive will be copied after install'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.3",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "type": "module",
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.9",
    "fflate": "^0.8.2",
    "libarchive.js": "^2.0.2"
  },
  "overrides": {
    "cookie": "1.1.1",
    "serialize-javascript": "7.0.5",
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
